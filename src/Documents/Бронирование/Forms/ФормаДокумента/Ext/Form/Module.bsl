&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	ОбщаяСумма = Объект.Цена;		Для Каждого Строка Из Объект.ДополнительныеУслуги Цикл		ОбщаяСумма = ОбщаяСумма + Строка.Сумма;	КонецЦикла;		Объект.Сумма = ОбщаяСумма; 
	Объект.СвободныеНомера.Очистить();
КонецПроцедуры

&НаКлиентеПроцедура ПоказатьСвободныеНомера(Команда)    ПоказатьСвободныеНомераНаСервере();КонецПроцедуры&НаСервереПроцедура ПоказатьСвободныеНомераНаСервере()        // Очищаем таблицу на закладке    Объект.СвободныеНомера.Очистить(); 		Запрос = Новый Запрос;    Запрос.Текст =        "ВЫБРАТЬ РАЗЛИЧНЫЕ       |	Номер.Ссылка КАК Ссылка,       |	Номер.Этаж КАК Этаж,       |	Номер.Категория КАК Категория,       |	Номер.КоличествоГостей КАК КоличествоГостей,       |	Цены.Цена КАК Цена       |ИЗ       |	Справочник.НомернойФонд КАК Номер       |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.БронированиеНомернойФонд КАК Бронь       |		ПО Номер.Ссылка = Бронь.НомернойФонд       |			И Бронь.Дата МЕЖДУ &ДатаЗаезда И &ДатаВыезда       |			И Бронь.Забронировано = ИСТИНА       |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦенаНомернойФонд.СрезПоследних(&ДатаЗаезда) КАК Цены       |		ПО Номер.Ссылка = Цены.НомернойФонд
	   |ГДЕ       |	Бронь.НомернойФонд ЕСТЬ NULL       |	И Номер.КоличествоГостей >= &КоличествоГостей";        Запрос.УстановитьПараметр("ДатаЗаезда", Объект.ДатаЗаезда);    Запрос.УстановитьПараметр("ДатаВыезда", Объект.ДатаВыезда);    Запрос.УстановитьПараметр("КоличествоГостей", Объект.КоличествоГостей);	    Выборка = Запрос.Выполнить().Выбрать();        Пока Выборка.Следующий() Цикл        Строка = Объект.СвободныеНомера.Добавить();        Строка.Номер = Выборка.Ссылка;        Строка.Категория = Выборка.Категория;        Строка.Этаж = Выборка.Этаж;        Строка.Вместимость = Выборка.КоличествоГостей;	Строка.Цена = Выборка.Цена;    КонецЦикла;    КонецПроцедуры


&НаКлиенте
Процедура СвободныеНомераВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если НЕ Объект.Проведен Тогда	
		ВыбраннаяСтрокаТаблицы = Элементы.СвободныеНомера.ТекущиеДанные;
    // Заполняем данные документа
		Объект.НомернойФонд = ВыбраннаяСтрокаТаблицы.Номер;
    	Объект.Цена = ВыбраннаяСтрокаТаблицы.Цена;
    
    // Переключаемся на основную страницу
   	 Элементы.Страницы.ТекущаяСтраница = Элементы.Основное;
	КонецЕсли;

КонецПроцедуры


&НаКлиенте
Процедура СписокУслугВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ВыбраннаяСтрокаТаблицы = Элементы.СписокУслуг.ТекущиеДанные;
	
	НоваяСтрока = Объект.ДополнительныеУслуги.Добавить();
	НоваяСтрока.Услуга = ВыбраннаяСтрокаТаблицы.Услуга;
	НоваяСтрока.Цена = ВыбраннаяСтрокаТаблицы.Цена; 
	
    // Переключаемся на основную страницу
   	 Элементы.Страницы.ТекущаяСтраница = Элементы.Основное;
КонецПроцедуры


&НаКлиенте
Процедура ДатаЗаездаПриИзменении(Элемент)
	РассчитатьКоличествоДней()
КонецПроцедуры 


&НаКлиенте
Процедура ДатаВыездаПриИзменении(Элемент)
	РассчитатьКоличествоДней()
КонецПроцедуры


&НаКлиентеПроцедура РассчитатьКоличествоДней()        // Проверяем что обе даты заполнены    Если НЕ ЗначениеЗаполнено(Объект.ДатаЗаезда)        ИЛИ НЕ ЗначениеЗаполнено(Объект.ДатаВыезда) Тогда        Объект.КоличествоДней = "0";        Возврат;    КонецЕсли;        // Вычисляем разницу в днях    Разница = Объект.ДатаВыезда - Объект.ДатаЗаезда;        // Если разница отрицательная или 0    Если Разница <= 0 Тогда        Объект.КоличествоДней = "0";    Иначе        Объект.КоличествоДней = Разница / (60*60*24);    КонецЕсли;    КонецПроцедуры


