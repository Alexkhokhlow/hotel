
&НаСервере
Процедура НомернойФондПриИзмененииНаСервере()
	
	//{{КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
	// Данный фрагмент построен конструктором.
	// При повторном использовании конструктора, внесенные вручную изменения будут утеряны!!!
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЦенаНомернойФондСрезПоследних.НомернойФонд КАК НомернойФонд,
		|	ЦенаНомернойФондСрезПоследних.Цена КАК Цена
		|ИЗ
		|	РегистрСведений.ЦенаНомернойФонд.СрезПоследних КАК ЦенаНомернойФондСрезПоследних
		|ГДЕ
		|	ЦенаНомернойФондСрезПоследних.НомернойФонд = &НомернойФонд";
	
	Запрос.УстановитьПараметр("НомернойФонд", Объект.НомернойФонд);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Объект.Цена = ВыборкаДетальныеЗаписи.Цена; 
	КонецЦикла;
	
	//}}КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
	
	
КонецПроцедуры

&НаКлиенте
Процедура НомернойФондПриИзменении(Элемент)
	НомернойФондПриИзмененииНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ДополнительныеУслугиУслугиПриИзменении(Элемент)   
	ТекущиеДанные = Элементы.ДополнительныеУслуги.ТекущиеДанные;	Услуга = ТекущиеДанные.Услуга;                   
	       	Цена = ОбработкаТабличнойЧастиВызовСервера.ТекущаяЦенаУслуги(Услуга);		ТекущиеДанные.Цена = Цена;	ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество; 
КонецПроцедуры

&НаКлиенте
Процедура ДополнительныеУслугиКоличествоПриИзменении(Элемент) 
	
		ТекущиеДанные = Элементы.ДополнительныеУслуги.ТекущиеДанные;
		ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество; 
		
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка) 
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		Объект.Менеджер = Пользователи.ТекущийПользователь();
	КонецЕсли; 
	
		Элементы.НомернойФонд.ТолькоПросмотр = Объект.Проведен;
		Элементы.Клиент.ТолькоПросмотр = Объект.Проведен;
		Элементы.ИнформацияОДатах.ТолькоПросмотр = Объект.Проведен;
		
		ЗаполнитьСписокУслуг()
КонецПроцедуры 

&НаСервере
Процедура ЗаполнитьСписокУслуг()
  	//{{КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
	// Данный фрагмент построен конструктором.
	// При повторном использовании конструктора, внесенные вручную изменения будут утеряны!!!
	Объект.СписокУслуг.Очистить();

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЦеныУслугСрезПоследних.Услуга КАК Услуга,
		|	ЦеныУслугСрезПоследних.Цена КАК Цена
		|ИЗ
		|	РегистрСведений.ЦеныУслуг.СрезПоследних(&Дата, ) КАК ЦеныУслугСрезПоследних";
	
	Запрос.УстановитьПараметр("Дата", ТекущаяДата());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
        НоваяСтрока = Объект.СписокУслуг.Добавить();		НоваяСтрока.Услуга = Выборка.Услуга;		НоваяСтрока.Цена = Выборка.Цена;	КонецЦикла;
	
	//}}КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА

КонецПроцедуры

